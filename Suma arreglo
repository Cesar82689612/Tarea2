#include <stdio.h>

int main ()
{ 
    int arr[10]; 
    int indice, sum=0;
    printf("Introduce 10 numeros enteros:\n");
    for (indice = 0; indice < 10; indice++)
    { 
        scanf("%d", &arr[indice]); 
        sum=sum+arr[indice];
    }

    printf("\nLos numeros introducidos son:\n");
    for (indice = 0; indice < 10; indice++)
    { 
        printf("%d\n", arr[indice]);
    }
    printf ("La suma del arreglo es:\n");
    printf ("%d", sum);
    return 0;
}
