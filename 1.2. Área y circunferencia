#include <stdio.h>
int main ()
{ 
  float r, A, C, pi=3.14159;
  printf ("Bienvenido al programa que te dará el área y circunferencia de un circulo.\n");
  printf ("Por favor, introduce el radio del circulo en metros.\n");
  scanf ("%f", &r);
  A=r*r*pi;
  printf ("El área es: %f metros\n", A);
  C=r*2*pi;
  printf ("La circunferencia es: %f metros\n", C);
  return 0;
}
  
