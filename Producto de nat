#include <stdio.h>
int main ()
{
  int v, n;
  double pro=1;
  printf ("Bievenido al programa que muestra el producto de los primeros naturales\n");
  printf ("Escriba hasta que numero natural se desea hacer el producto\n");
  scanf ("%d", &v);
  printf ("\n");
  for (n=1; n<=v; n++)
  {
    pro=pro*n;
  }
  printf ("el producto desde 1 hasta %d = %lf \n",v,pro);
  return 0;
}
